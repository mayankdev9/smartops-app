# SmartOps environment variables
#
# The Chat screen works today against a built-in MOCK — no key required.
#
# Later, wiring in Ahmer's real pipeline uses ONE of these (see app/api/assistant/route.ts):
#   Option 1 — Ahmer's LLM runs inside this route:
# ANTHROPIC_API_KEY=sk-ant-...
#   Option 2 — Ahmer's LLM is a separate service; this route proxies to it:
# ASSISTANT_BACKEND_URL=https://ahmers-backend.example.com/query
